# Google OAuth — required for Drive backup
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Mobile (recommended for Android/iOS builds; stops 400 / access blocked on phones)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# GitHub Pages subpath (local test only; CI sets this automatically)
# EXPO_PUBLIC_BASE_PATH=/study-focus-app
