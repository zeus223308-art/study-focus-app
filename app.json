{
  "expo": {
    "name": "MemorySherpa",
    "slug": "study-focus-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "memorysherpa",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001A33"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memorysherpa.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "공부 내용을 촬영해 Files에 저장합니다.",
        "NSPhotoLibraryUsageDescription": "촬영한 사진을 앱에 저장합니다."
      }
    },
    "android": {
      "package": "com.memorysherpa.app",
      "versionCode": 1,
      "permissions": ["CAMERA", "RECEIVE_BOOT_COMPLETED", "VIBRATE"],
      "adaptiveIcon": {
        "backgroundColor": "#001A33",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#001A33"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "공부 내용을 촬영해 저장합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E85D04"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
